---
import "../styles/global.css";
import SectionNav from "../components/SectionNav.astro";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Jacob Marriott — software engineering student at UQ",
  description = "Software engineering student at UQ building tools for real-world operations. Brisbane · Queenstown.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="color-scheme" content="dark" />
    <title>{title}</title>
    <meta name="description" content={description} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Geist+Mono:wght@400;500&display=swap"
    />
  </head>
  <body>
    <SectionNav />
    <main>
      <slot />
    </main>
  </body>
</html>
