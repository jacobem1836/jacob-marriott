---
---

<section id="intro" class="hero container" aria-labelledby="hero-heading">
  <p class="section-label hero__label">
    <span aria-hidden="true">01 / </span>intro
  </p>

  <h1 id="hero-heading" class="hero__headline">
    Jacob Marriott
    <span class="hero__headline-soft">software engineering student at&nbsp;UQ.</span>
  </h1>

  <p class="hero__lede">
    I connect people and systems. I build software to solve real problems —
    for a hospitality operator running end-of-service, a record collector
    chasing a second-hand pressing, or myself, my friends, and my family
    when the existing tools don't quite fit.
    <span class="hero__lede-emphasis">
      <code>Communication</code> is the feature I care about most.
    </span>
  </p>

  <p class="hero__meta">
    <span>Brisbane</span>
    <span class="hero__meta-dot" aria-hidden="true">·</span>
    <span>Queenstown</span>
    <span class="hero__meta-dot" aria-hidden="true">·</span>
    <span>available for 2026/27 internships</span>
    <span class="hero__cursor" aria-hidden="true">▍</span>
  </p>
</section>

<style>
  .hero {
    padding-block: clamp(6rem, 4rem + 10vw, 12rem) var(--space-section);
    display: grid;
    gap: var(--space-8);
  }

  .hero__label {
    display: inline-flex;
    align-items: center;
    gap: 0.25em;
    color: var(--color-accent-muted);
  }

  .hero__headline {
    font-size: clamp(2.75rem, 1.8rem + 5.5vw, 6rem);
    line-height: 1.02;
    letter-spacing: -0.03em;
    font-weight: 700;
    max-width: 14ch;
  }

  .hero__headline-soft {
    display: block;
    font-size: clamp(1rem, 0.85rem + 0.8vw, 1.375rem);
    color: var(--color-text-muted);
    font-weight: 400;
    letter-spacing: var(--tracking-tight);
    margin-top: var(--space-4);
  }

  .hero__lede {
    font-size: var(--text-lg);
    color: var(--color-text);
    max-width: 58ch;
    line-height: var(--leading-prose);
  }

  .hero__lede-emphasis {
    display: inline;
    color: var(--color-text-muted);
  }

  .hero__lede code {
    background: var(--color-accent-bg);
    color: var(--color-accent);
  }

  .hero__meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-2) var(--space-3);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-mono);
    text-transform: lowercase;
    color: var(--color-text-muted);
    margin-top: var(--space-4);
  }

  .hero__meta-dot {
    color: var(--color-text-dim);
  }

  .hero__cursor {
    display: inline-block;
    color: var(--color-accent);
    margin-left: 0.15em;
    transform: translateY(-0.05em);
    animation: cursor-blink 1.1s steps(1, end) infinite;
  }

  @keyframes cursor-blink {
    0%, 50%   { opacity: 1; }
    50.01%, 100% { opacity: 0; }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero__cursor {
      animation: none;
      opacity: 1;
    }
  }

  @media (min-width: 48rem) {
    .hero {
      grid-template-columns: minmax(0, 1fr);
    }
    .hero__lede {
      padding-left: clamp(0rem, -2rem + 10vw, 8rem);
    }
    .hero__meta {
      padding-left: clamp(0rem, -2rem + 10vw, 8rem);
    }
  }
</style>
