---
---

<section id="services" class="services container" aria-labelledby="services-heading">
  <p class="section-label services__label">
    <span aria-hidden="true">05 / </span>services
  </p>

  <h2 id="services-heading" class="visually-hidden">Websites for Brisbane businesses</h2>

  <p class="services__lede">
    Get found online. A clean, custom website for your Brisbane business —
    built fast, no&nbsp;templates.
  </p>

  <div class="services__grid">
    <div class="services__col">
      <p class="services__col-label mono">what I build</p>
      <ul class="services__list">
        <li>Custom website design and build</li>
        <li>Mobile-first and responsive</li>
        <li>Built for local Brisbane businesses</li>
        <li>Free mockup before you commit</li>
      </ul>
    </div>

    <div class="services__col">
      <p class="services__col-label mono">how it works</p>
      <ol class="services__steps">
        <li class="services__step">
          <span class="services__step-num mono" aria-hidden="true">01</span>
          <div class="services__step-detail">
            <p class="services__step-title">I put together a free mockup of your site</p>
            <p class="services__step-body">
              You see what your site could look like — before anything is agreed.
            </p>
          </div>
        </li>
        <li class="services__step">
          <span class="services__step-num mono" aria-hidden="true">02</span>
          <div class="services__step-detail">
            <p class="services__step-title">You review it — no obligation</p>
            <p class="services__step-body">
              Like what you see? We talk through it. Not for you? No cost, no pressure.
            </p>
          </div>
        </li>
        <li class="services__step">
          <span class="services__step-num mono" aria-hidden="true">03</span>
          <div class="services__step-detail">
            <p class="services__step-title">If you like it, we build it</p>
            <p class="services__step-body">
              Competitive pricing, transparent from day one. Contact me for a quote.
            </p>
          </div>
        </li>
      </ol>
    </div>
  </div>

  <p class="services__cta">
    <a href="mailto:jacobemarriott@icloud.com">
      request a free mockup <span aria-hidden="true">→</span>
    </a>
  </p>
</section>

<style>
  .services {
    display: grid;
    gap: var(--space-12);
  }

  .services__label {
    color: var(--color-accent-muted);
  }

  .services__lede {
    font-size: var(--text-lg);
    max-width: 52ch;
    line-height: var(--leading-prose);
    color: var(--color-text);
  }

  /* Two-column layout */
  .services__grid {
    display: grid;
    gap: var(--space-12);
  }

  .services__col-label {
    font-size: var(--text-xs);
    color: var(--color-text-dim);
    text-transform: lowercase;
    max-width: none;
    margin-bottom: var(--space-5);
  }

  /* Offer list */
  .services__list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: var(--space-3);
  }

  .services__list li {
    display: flex;
    align-items: baseline;
    gap: var(--space-3);
    font-size: var(--text-base);
    color: var(--color-text-muted);
    line-height: var(--leading-prose);
  }

  .services__list li::before {
    content: "→";
    color: var(--color-accent);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    flex-shrink: 0;
  }

  /* Step list */
  .services__steps {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
  }

  .services__step {
    display: grid;
    gap: var(--space-2);
    padding-block: var(--space-5);
    border-top: 1px solid var(--color-border);
  }

  .services__step:first-child {
    border-top: 0;
    padding-top: 0;
  }

  .services__step-num {
    font-size: var(--text-xs);
    color: var(--color-text-dim);
    text-transform: lowercase;
  }

  .services__step-title {
    font-size: var(--text-base);
    font-weight: 600;
    letter-spacing: 0;
    line-height: 1.3;
    color: var(--color-text);
    font-family: var(--font-sans);
    max-width: none;
  }

  .services__step-body {
    font-size: var(--text-base);
    color: var(--color-text-muted);
    max-width: 42ch;
    line-height: var(--leading-prose);
  }

  /* CTA */
  .services__cta {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    max-width: none;
  }

  @media (min-width: 48rem) {
    .services__lede {
      padding-left: clamp(0rem, -2rem + 10vw, 8rem);
    }

    .services__grid {
      grid-template-columns: 1fr 1fr;
      gap: clamp(2rem, 1rem + 5vw, 5rem);
    }

    .services__step {
      grid-template-columns: 3rem minmax(0, 1fr);
      gap: clamp(1rem, -0.5rem + 4vw, 2rem);
      align-items: start;
    }
  }
</style>
